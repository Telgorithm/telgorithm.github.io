ted-number-porting/"}}},{"node":{"frontmatter":{"articleType":"BLOG POST","date":"August 18, 2023","title":"The #1 SMS API Twilio Alternative ","previewImage":{"childrenImageSharp":[{"gatsbyImageData":{"layout":"fixed","backgroundColor":"#e8e8f8","images":{"fallback":{"src":"/static/2f636c1c45b12faca7044d143f0e265b/f3ceb/blog-banner-image-2-.webp","srcSet":"/static/2f636c1c45b12faca7044d143f0e265b/f3ceb/blog-banner-image-2-.webp 1000w","sizes":"1000px"},"sources":[]},"width":1000,"height":389}}]}},"id":"9027330b-7053-59c9-8eef-1c1b83d8d026","fields":{"slug":"twilio-alternative-sms-api/"}}},{"node":{"frontmatter":{"articleType":"BLOG POST","date":"July 26, 2023","title":"Hosted Messaging Means the Best of Both Worlds for Your Voice and SMS/MMS Needs","previewImage":{"childrenImageSharp":[{"gatsbyImageData":{"layout":"fixed","backgroundColor":"#f8f8f8","images":{"fallback":{"src":"/static/2c51158f327f3704b1d8bfb35941f19f/ef757/shutterstock_1478223662.webp","srcSet":"/static/2c51158f327f3704b1d8bfb35941f19f/ef757/shutterstock_1478223662.webp 1000w","sizes":"1000px"},"sources":[]},"width":1000,"height":633}}]}},"id":"c5466cac-6254-5843-9f96-283f968393a9","fields":{"slug":"hosted-messaging-provider/"}}},{"node":{"frontmatter":{"articleType":"BLOG POST","date":"July 22, 2023","title":"How to Avoid TCR Brand & Campaign Rejections the First Time Around","previewImage":{"childrenImageSharp":[{"gatsbyImageData":{"layout":"fixed","backgroundColor":"#f8f8f8","images":{"fallback":{"src":"/static/2739a32c0a33b694742ec07d426da89c/7a1b6/shutterstock_1395298508.webp","srcSet":"/static/2739a32c0a33b694742ec07d426da89c/7a1b6/shutterstock_1395298508.webp 1000w","sizes":"1000px"},"sources":[]},"width":1000,"height":667}}]}},"id":"65c875f7-b0c8-564b-a4c5-15f5fac9ab8f","fields":{"slug":"brand-campaign-rejections/"}}},{"node":{"frontmatter":{"articleType":"BLOG POST","date":"July 12, 2023","title":"Want to provide your customers with unmatched SMS & MMS deliverability? Here’s how.","previe